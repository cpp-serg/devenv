         struct avp *avp, ogs_pcc_rule_t *pcc_rule, int flow_presence);
 
+/* Local PCC rule synthesizer for IMS audio Rx-derived rules.
+ * Produces prod-shape RARs:
+ *   - one Charging-Rule-Install per Media-Sub-Component
+ *   - per-sub flows only (RTP or RTCP, not merged)
+ *   - rule name "IMS_AudioRule_<RTP|RTCP>_<af-id1>_<af-id2>"
+ *   - QCI=1, ARP priority=8 PCI=Enabled PVI=Disabled,
+ *     MBR=GBR=max_requested_bandwidth (50k for VoLTE), Precedence=0
+ *   - Service-Identifier=1000, Rating-Group=1000, Reporting-Level=SI,
+ *     Online/Offline=DISABLE, Metering=VOLUME (added by encode helper).
+ * AF-IDs are derived deterministically from (rx_sid, media_comp, sub_idx)
+ * so re-AAR / STR can find the same rule slot. */
+#define IMS_RULE_NAME_MAX 128
+#define IMS_PROD_RULE_RATING_GROUP 1000
+#define IMS_PROD_RULE_SERVICE_ID   1000
+#define IMS_PROD_ARP_PRIORITY      8
+
+static uint64_t ims_fnv64(const uint8_t *data, size_t len, uint64_t seed)
+{
+    uint64_t h = 0xcbf29ce484222325UL ^ seed;
+    for (size_t i = 0; i < len; i++) {
+        h ^= data[i];
+        h *= 0x100000001b3UL;
+    }
+    return h;
+}
+
+static void ims_build_rule_name(
+        char *out, size_t out_sz,
+        const uint8_t *rx_sid, int media_comp_num, int sub_idx, int is_rtcp)
+{
+    uint64_t af1, af2;
+    size_t sid_len = rx_sid ? strlen((const char *)rx_sid) : 0;
+    af1 = ims_fnv64(rx_sid, sid_len,
+            ((uint64_t)media_comp_num << 32) | (uint64_t)sub_idx);
+    af2 = ims_fnv64(rx_sid, sid_len,
+            0x9e3779b97f4a7c15UL ^ (((uint64_t)media_comp_num << 16) | sub_idx));
+    snprintf(out, out_sz, "IMS_AudioRule_%s_%016lx_%016lx",
+             is_rtcp ? "RTCP" : "RTP",
+             (unsigned long)af1, (unsigned long)af2);
+}
+
+static int ims_install_flow_from_one_sub(
+        ogs_pcc_rule_t *pcc_rule, ogs_media_sub_component_t *sub)
+{
+    int i, rv;
+
+    /* Wipe any existing flows; we own this rule per-sub. */
+    for (i = 0; i < pcc_rule->num_of_flow; i++)
+        OGS_FLOW_FREE(&pcc_rule->flow[i]);
+    pcc_rule->num_of_flow = 0;
+
+    for (i = 0; i < sub->num_of_flow &&
+                i < OGS_MAX_NUM_OF_FLOW_IN_MEDIA_SUB_COMPONENT; i++) {
+        ogs_flow_t *gx_flow = NULL;
+        ogs_flow_t *rx_flow = &sub->flow[i];
+
+        if (pcc_rule->num_of_flow >= OGS_MAX_NUM_OF_FLOW_IN_PCC_RULE) {
+            ogs_error("Overflow: Number of Flow per PCC rule");
+            return OGS_ERROR;
+        }
+        gx_flow = &pcc_rule->flow[pcc_rule->num_of_flow];
+
+        /* Reuse existing flow_rx_to_gx via a 1-flow throwaway sub, but the
+         * function is static in lib/proto/types.c, so inline the conversion
+         * here: rewrite "permit in/out" to "permit out" flipping addresses,
+         * mark direction. We mirror what flow_rx_to_gx does. */
+        {
+            char *desc = rx_flow->description;
+            int direction = OGS_FLOW_BIDIRECTIONAL;
+            if (desc) {
+                if (strncmp(desc, "permit out", 10) == 0)
+                    direction = OGS_FLOW_DOWNLINK_ONLY;
+                else if (strncmp(desc, "permit in", 9) == 0)
+                    direction = OGS_FLOW_UPLINK_ONLY;
+            }
+            gx_flow->direction = direction;
+            gx_flow->description = ogs_strdup(desc ? desc : "");
+            if (!gx_flow->description) return OGS_ERROR;
+        }
+        pcc_rule->num_of_flow++;
+        (void)rv;
+    }
+    return OGS_OK;
+}
